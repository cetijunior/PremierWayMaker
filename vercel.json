{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "api/src/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin(.*)",
      "destination": "/admin/dist/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/app/dist/index.html"
    }
  ]
}