# ============================================================
# Premier Way Maker — Environment Variables
# Copy this file to .env and fill in all values.
# ============================================================

# --- Database ---
MONGODB_URI=                        # e.g. mongodb+srv://user:pass@cluster.mongodb.net/pwmaker

# --- API Server ---
PORT=5001
NODE_ENV=development                # 'development' | 'production'

# --- Admin Auth ---
JWT_SECRET=                         # Long random string, e.g. openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                     # Strong password for the admin dashboard

# --- URLs ---
CLIENT_URL=http://localhost:3000    # Public app URL (e.g. https://premierwaymaker.com)
ADMIN_URL=http://localhost:3001     # Admin URL (e.g. https://premierwaymaker.com/admin)

# --- PayPal ---
# Get from https://developer.paypal.com/dashboard/applications
PAYPAL_ENV=sandbox                  # 'sandbox' for testing, 'live' for production
PAYPAL_CLIENT_ID=                   # App Client ID
PAYPAL_CLIENT_SECRET=               # App Secret
PAYPAL_WEBHOOK_ID=                  # (Optional but recommended) Webhook ID from PayPal dashboard

# --- Email (Gmail SMTP) ---
# GMAIL_USER: the Gmail address that sends emails
# GMAIL_APP_PASSWORD: a 16-character App Password (NOT your Gmail login password)
#   Generate at: https://myaccount.google.com/apppasswords
#   Requires 2FA to be enabled on the Google account.
GMAIL_USER=premierwaymaker@gmail.com
GMAIL_APP_PASSWORD=                 # e.g. abcd efgh ijkl mnop (spaces optional)

# --- Vercel Blob (CV uploads on Vercel) ---
# Only required when deployed to Vercel.
# Create a Blob store in Vercel dashboard → Storage → Blob.
BLOB_READ_WRITE_TOKEN=

# --- App build-time (Vite bakes these in at build time) ---
VITE_PAYPAL_CLIENT_ID=              # Same value as PAYPAL_CLIENT_ID above
